# PlaceReady Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env file to git!

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
VITE_API_URL="http://localhost:5000"

# ============================================================================
# BACKEND - DATABASE
# ============================================================================
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp"

# ============================================================================
# BACKEND - AUTHENTICATION
# ============================================================================
JWT_SECRET="your-secret-key-min-32-chars-long-change-in-production"

# ============================================================================
# BACKEND - EMAIL SERVICE (Gmail)
# ============================================================================
GMAIL_EMAIL="your-email@gmail.com"
GMAIL_PASSWORD="your-app-specific-password"

# ============================================================================
# BACKEND - AI RECOMMENDATION ENGINE (Priority: NIM > Gemini > Ollama)
# ============================================================================

# PRIMARY: NVIDIA NIM - Free tier with no rate limits
# Get your free API key from: https://build.nvidia.com/meta/llama-3-1-70b-instruct
# Steps:
# 1. Visit https://build.nvidia.com/
# 2. Sign up/login
# 3. Go to Llama 3.1 70B Instruct
# 4. Click "Get API Key"
# 5. Create a new API key and copy it here
NVIDIA_NIM_KEY="your-nvidia-nim-api-key-here"

# FALLBACK 1: Google Gemini API - Limited free tier (429 rate limit errors)
# Get your Gemini API key from: https://aistudio.google.com/app/apikey
# Note: Free tier has rate limits, NIM is preferred
GEMINI_API_KEY="your-google-gemini-api-key"

# FALLBACK 2: Ollama - Local LLM (requires Ollama to be running locally)
# Install from: https://ollama.ai
# Run: ollama pull mistral
# Then run: ollama serve
# API endpoint: http://localhost:11434/api/generate

# ============================================================================
# FRONTEND - SUPABASE (OPTIONAL - if using Supabase auth)
# ============================================================================
# VITE_SUPABASE_URL="your-supabase-project-url"
# VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-key"
